// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             User Table                                                                 |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model User {
  id              String   @id @default(cuid())
  email           String   @unique @db.VarChar(255)
  firstName       String   @map("first_name") @db.VarChar(100)
  lastName        String   @map("last_name") @db.VarChar(100)
  passwordHash    String?  @map("password_hash")
  avatarUrl       String?  @map("avatar_url")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  googleId        String?  @unique @map("google_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Relations
  orgMembers    OrgMember[]
  projects      Project[]
  invitations   Invitation[]
  assignedTasks Task[]         @relation("TaskAssignee")
  reportedTasks Task[]         @relation("TaskReporter")
  comments      Comment[]
  activities    Activity[]
  notifications Notification[]
  attachments   Attachment[]
  refreshTokens RefreshToken[]
  savedFilters  SavedFilter[]

  @@map("users")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Organisation Table                                                         |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Organisation {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(50) // For organisation url
  description String?
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  orgMembers  OrgMember[]
  projects    Project[]
  invitations Invitation[]

  @@map("organisations")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             OrgMember Table                                                            |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model OrgMember {
  id       String   @id @default(cuid())
  role     Role
  joinedAt DateTime @default(now()) @map("joined_at")

  // Foreign Keys
  userId         String @map("user_id")
  organisationId String @map("organisation_id")

  // Realtionships
  user         User         @relation(fields: [userId], references: [id])
  organisation Organisation @relation(fields: [organisationId], references: [id])

  // constraints
  @@unique([userId, organisationId])
  // Indeicies
  @@index([userId])
  @@index([organisationId])
  @@map("org_members")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Project Table                                                              |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Project {
  id          String   @id @default(cuid())
  taskCounter Int      @default(0) @map("task_counter")
  name        String   @db.VarChar(255)
  key         String   @db.VarChar(5)
  description String?
  icon        String?
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  organisationId String  @map("organisation_id")
  leadId         String? @map("lead_id")

  // Relationships
  organisation Organisation @relation(fields: [organisationId], references: [id])
  lead         User?        @relation(fields: [leadId], references: [id])

  // Relations
  statuses     Status[]
  labels       Label[]
  tasks        Task[]
  savedFilters SavedFilter[]

  // COnstraints
  @@unique([organisationId, key])
  @@map("projects")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Invitation Table                                                           |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Invitation {
  id         String    @id @default(cuid())
  email      String    @db.VarChar(255)
  role       Role // Role will be defined invitee
  token      String    @unique
  createdAt  DateTime  @default(now()) @map("created_at")
  expiresAt  DateTime  @map("expires_at")
  acceptedAt DateTime? @map("accepted_at")

  //Foreign Keys
  organisationId String @map("organisation_id")
  invitedBy      String @map("invited_by")

  // Relationships
  organisation Organisation @relation(fields: [organisationId], references: [id])
  invitee      User         @relation(fields: [invitedBy], references: [id])

  @@map("invitations")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Status Table                                                           |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Status {
  id    String @id @default(cuid())
  name  String @db.VarChar(255)
  color String @db.VarChar(20)
  order Int // For ordering status

  // Foreign Keys
  projectId String @map("project_id")

  // Relationships
  project Project @relation(fields: [projectId], references: [id])

  // Relations
  tasks Task[]

  // constraints
  @@unique([projectId, name])
  @@unique([order, projectId])
  @@map("statuses")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Label Table                                                                |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Label {
  id    String @id @default(cuid())
  name  String @db.VarChar(255)
  color String @db.VarChar(20)

  // Foreign key
  projectId String @map("project_id")

  // Relationships
  project    Project     @relation(fields: [projectId], references: [id])
  taskLabels TaskLabel[]

  // constraints
  @@unique([projectId, name])
  @@map("labels")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Task Table                                                                 |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

enum TASKPriority {
  URGENT
  HIGHT
  MEDIUM
  LOW
  NONE
}

model Task {
  id             String       @id @default(cuid())
  title          String       @db.VarChar(255)
  description    Json?
  priority       TASKPriority
  taskNumber     Int          @map("task_number")
  dueDate        DateTime?    @map("due_date")
  estimatedHours Float?       @map("estimated_hours")
  order          Int // Ordering within status
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  deletedAt      DateTime?    @map("deleted_at")

  // Foreign Keys
  projectId    String  @map("project_id")
  statusId     String  @map("status_id")
  assigneeId   String? @map("assignee_id")
  reporterId   String  @map("reporter_id")
  parentTaskId String? @map("parent_task_id")

  // Relationships
  project    Project @relation(fields: [projectId], references: [id])
  status     Status  @relation(fields: [statusId], references: [id])
  assignee   User?   @relation("TaskAssignee", fields: [assigneeId], references: [id])
  reporter   User    @relation("TaskReporter", fields: [reporterId], references: [id])
  ParentTask Task?   @relation("TaskHierarchy", fields: [parentTaskId], references: [id])

  // Relations
  tasks       Task[]       @relation("TaskHierarchy")
  taskLabels  TaskLabel[]
  comments    Comment[]
  activities  Activity[]
  attachments Attachment[]

  // constraints
  @@index([projectId])
  @@index([assigneeId, statusId])
  @@index([dueDate])
  @@map("tasks")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             TaskLabel Table (junction table)                                           |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model TaskLabel {
  // Foreign
  taskId  String @map("task_id")
  labelId String @map("label_id")

  // Relationships
  task  Task  @relation(fields: [taskId], references: [id])
  label Label @relation(fields: [labelId], references: [id])

  // constraints
  @@id([taskId, labelId])
  @@map("task_labels")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Comment Table                                                              |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Foreign Keys
  taskId   String @map("task_id")
  authorId String @map("author_id")

  // Relationships
  task   Task @relation(fields: [taskId], references: [id])
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId])
  @@map("comments")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Activity Table                                                             |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

enum ActivityAction {
  // CRUD Actions
  CREATED
  DELETED
  UPDATED

  // Changes
  STATUS_CHANGED
  PRIORITY_CHANGED
  ASSIGNED
  UNASSIGNED

  // writes
  COMMENTED
  ATTACHEMNT_ADDED

  // misc
  MOVED
  OTHER
}

model Activity {
  id         String         @id @default(cuid())
  action     ActivityAction
  oldValue   String?        @map("old_value")
  newValue   String?        @map("new_value")
  created_at DateTime       @default(now())

  // Foreign Keys
  taskId  String @map("task_id")
  actorId String @map("actor_id")

  // Relationships
  task  Task @relation(fields: [taskId], references: [id])
  actor User @relation(fields: [actorId], references: [id])

  // constraints
  @@index([taskId, created_at])
  @@map("activities")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Notification Table                                                         |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

// TODO: Complete this type later
enum NotificationType {
  // Task Action
  TASK_ASSIGNED
  TASK_UNASSIGNED
  TASK_CREATED
  TASK_UPDATED
  TASK_DELTED
  TASK_DUE_SOON
  TASK_OVERDUE

  // Comment Action
  COMMENT_ADDED
  MENTIONED_IN_COMMENT
  REPLY_TO_COMMENT

  // Project Action
  PROJECT_CREATED
  PROJECT_UPDATED
  MEMBER_ADDED
  MEMBER_REMOVED
  ROLE_CHANGED

  // Attachment Action
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED

  // Invitation
  INVITATION_RECIEVED
  INVITATION_ACCEPTED

  // User Action
  PASSWORD_CHANGED

  // Misc
  OTHER
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String           @db.VarChar(50)
  message   String
  link      String
  isRead    Boolean          @default(false) @map("is_read")
  createdAt DateTime         @map("created_at")

  // Foreign Keys
  userId String @map("user_id")

  // Relationships
  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             Attachment Table                                                           |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model Attachment {
  id        String   @id @default(cuid())
  fileName  String   @map("file_name") @db.VarChar(80)
  url       String
  fileSize  Int      @map("file_size")
  mimeType  String   @map("mime_type") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  // Foreign Keys
  taskId     String @map("task_id")
  uploaderId String @map("uploader_id")

  // Relationships
  task     Task @relation(fields: [taskId], references: [id])
  uploader User @relation(fields: [uploaderId], references: [id])

  @@index([taskId])
  @@map("attachments")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             RefreshToken Table                                                         |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  // Foreign Keys
  userId String @map("user_id")

  // Relationships
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("refresh_Token")
}

/**
 * |========================================================================================================================|
 * |========================================================================================================================|
 * |                                             SavedFilter Table                                                          |
 * |                                                                                                                        |
 * |========================================================================================================================|
 * |========================================================================================================================|
 */

model SavedFilter {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(50)
  filters   Json
  createdAt DateTime @default(now()) @map("created_at")

  // Foreign Keys
  projectId String @map("project_id")
  createdBy String @map("created_by")

  // Relationships
  proejct Project @relation(fields: [projectId], references: [id])
  creator User    @relation(fields: [createdBy], references: [id])

  @@map("save_filter")
}
